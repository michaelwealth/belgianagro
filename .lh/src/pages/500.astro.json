            "content": "---\nimport { Image } from 'astro:assets';\nimport fitLogo from '../assets/images/fit_logo.png';\nimport Footer from '../components/Footer.astro';\n---\n\n<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>Server error — Belgian Pavilion</title>\n  </head>\n  <body class=\"font-inter bg-white text-gray-900 antialiased min-h-screen flex flex-col\">\n    <!-- Minimal header (logo only) -->\n    <header class=\"w-full py-4\">\n      <div class=\"max-w-7xl mx-auto px-6 lg:px-12 flex items-center\">\n        <a href=\"/\" aria-label=\"Home\" class=\"inline-block\">\n          <Image src={fitLogo} alt=\"FIT logo\" width={160} height={48} class=\"h-10 w-auto\" />\n        </a>\n      </div>\n    </header>\n\n    <!-- Hero -->\n    <main class=\"flex-1 flex items-center justify-center\">\n      <div class=\"max-w-4xl mx-auto text-center px-6 py-20\">\n        <div class=\"inline-flex items-center justify-center w-36 h-36 rounded-full bg-bg-glow/70 mx-auto mb-8 shadow-xl\">\n          <h1 class=\"text-4xl font-jakarta font-extrabold text-text-main\">500</h1>\n        </div>\n        <h2 class=\"text-3xl md:text-4xl font-jakarta font-bold mb-4\">Something went wrong</h2>\n        <p class=\"text-gray-600 mb-8\">We're experiencing a server error. Try refreshing the page or come back later.</p>\n\n        <div class=\"flex flex-col sm:flex-row gap-3 justify-center\">\n          <button onclick=\"location.reload()\" class=\"btn-blue inline-flex items-center justify-center px-6 py-3 rounded-full font-semibold\">Retry</button>\n          <a href=\"/#companies\" class=\"inline-flex items-center justify-center px-6 py-3 rounded-full border border-gray-200 text-text-main hover:bg-gray-50\">View companies</a>\n        </div>\n      </div>\n    </main>\n\n    <Footer />\n  </body>\n</html>\n"
