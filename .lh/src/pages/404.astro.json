            "content": "---\nimport { Image } from 'astro:assets';\nimport fitLogo from '../assets/images/fit_logo.png';\nimport Footer from '../components/Footer.astro';\n---\n\n<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>Page not found — Belgian Pavilion</title>\n  </head>\n  <body class=\"font-inter bg-white text-gray-900 antialiased min-h-screen flex flex-col\">\n    <!-- Minimal header (logo only) -->\n    <header class=\"w-full py-4\">\n      <div class=\"max-w-7xl mx-auto px-6 lg:px-12 flex items-center\">\n        <a href=\"/\" aria-label=\"Home\" class=\"inline-block\">\n          <Image src={fitLogo} alt=\"FIT logo\" width={160} height={48} class=\"h-10 w-auto\" />\n        </a>\n      </div>\n    </header>\n\n    <!-- Hero -->\n    <main class=\"flex-1 flex items-center justify-center\">\n      <div class=\"max-w-4xl mx-auto text-center px-6 py-20\">\n        <div class=\"inline-flex items-center justify-center w-36 h-36 rounded-full bg-card-yellow/80 mx-auto mb-8 shadow-xl\">\n          <h1 class=\"text-5xl font-jakarta font-extrabold text-text-main\">404: Mission delayed</h1>\n        </div>\n        <h2 class=\"text-3xl md:text-4xl font-jakarta font-bold mb-4\">Page not found</h2>\n        <p class=\"text-gray-600 mb-8\">It seems we took a wrong turn at the Port of Antwerp.</p>\n\n        <div class=\"flex flex-col sm:flex-row gap-3 justify-center\">\n          <a href=\"/\" class=\"btn-blue inline-flex items-center justify-center px-6 py-3 rounded-full font-semibold\">Return home</a>\n          <a href=\"/#companies\" class=\"inline-flex items-center justify-center px-6 py-3 rounded-full border border-gray-200 text-text-main hover:bg-gray-50\">View companies</a>\n        </div>\n      </div>\n    </main>\n\n    <Footer />\n  </body>\n</html>\n"
