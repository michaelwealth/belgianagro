            "name": "Commit-0",
            "content": "---\n/**\n * Cookie Consent Banner\n * GDPR (EU) and NDPR (Nigeria) compliant with granular consent options.\n * Fixed to bottom of screen with dark-mode styling.\n */\n---\n\n<div\n  id=\"cookie-banner\"\n  class=\"fixed bottom-4 left-4 right-4 md:w-max md:max-w-2xl md:left-1/2 md:-translate-x-1/2 z-[100] opacity-0 pointer-events-none transition-opacity duration-500\"\n  role=\"dialog\"\n  aria-label=\"Cookie consent\"\n  aria-modal=\"false\"\n>\n  <div class=\"bg-gray-900 text-white rounded-2xl p-6 shadow-2xl\">\n    <div class=\"flex flex-col gap-4\">\n      <!-- Header -->\n      <div class=\"flex items-start justify-between gap-4\">\n        <div>\n          <h3 class=\"font-jakarta font-bold text-base mb-1\">We value your privacy</h3>\n          <p class=\"text-gray-400 text-xs leading-relaxed\">\n            We use cookies to enhance your browsing experience, serve personalized content, and analyze site traffic. Under GDPR and NDPR regulations, we need your consent.\n          </p>\n        </div>\n      </div>\n\n      <!-- Consent Options -->\n      <div class=\"flex flex-col sm:flex-row gap-3 sm:gap-6\">\n        <label class=\"flex items-center gap-2 text-sm cursor-not-allowed\">\n          <input\n            type=\"checkbox\"\n            checked\n            disabled\n            class=\"w-4 h-4 rounded accent-white\"\n          />\n          <span class=\"text-gray-300\">Necessary</span>\n        </label>\n        <label class=\"flex items-center gap-2 text-sm cursor-pointer group\">\n          <input\n            type=\"checkbox\"\n            id=\"cookie-analytics\"\n            class=\"w-4 h-4 rounded accent-white cursor-pointer\"\n          />\n          <span class=\"text-gray-300 group-hover:text-white transition-colors\">Analytics</span>\n        </label>\n        <label class=\"flex items-center gap-2 text-sm cursor-pointer group\">\n          <input\n            type=\"checkbox\"\n            id=\"cookie-marketing\"\n            class=\"w-4 h-4 rounded accent-white cursor-pointer\"\n          />\n          <span class=\"text-gray-300 group-hover:text-white transition-colors\">Marketing</span>\n        </label>\n      </div>\n\n      <!-- Action Buttons -->\n      <div class=\"flex flex-col sm:flex-row gap-2 sm:gap-3\">\n        <button\n          id=\"cookie-accept-all\"\n          class=\"bg-white text-gray-900 hover:bg-gray-200 text-sm font-semibold px-5 py-2.5 rounded-full transition-colors duration-200 flex-1 sm:flex-none\"\n        >\n          Accept All\n        </button>\n        <button\n          id=\"cookie-accept-selected\"\n          class=\"bg-white/10 hover:bg-white/20 text-white text-sm font-medium px-5 py-2.5 rounded-full transition-colors duration-200 border border-white/20 flex-1 sm:flex-none\"\n        >\n          Accept Selected\n        </button>\n        <button\n          id=\"cookie-reject\"\n          class=\"text-gray-400 hover:text-white text-sm font-medium px-5 py-2.5 transition-colors duration-200 flex-1 sm:flex-none\"\n        >\n          Reject Optional\n        </button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  const banner = document.getElementById('cookie-banner') as HTMLElement;\n  const acceptAll = document.getElementById('cookie-accept-all') as HTMLButtonElement;\n  const acceptSelected = document.getElementById('cookie-accept-selected') as HTMLButtonElement;\n  const rejectAll = document.getElementById('cookie-reject') as HTMLButtonElement;\n  const analyticsCheckbox = document.getElementById('cookie-analytics') as HTMLInputElement;\n  const marketingCheckbox = document.getElementById('cookie-marketing') as HTMLInputElement;\n\n  // Check if consent already given\n  const consentGiven = localStorage.getItem('cookie-consent');\n\n  if (!consentGiven) {\n    // Show banner after a short delay for better UX\n    setTimeout(() => {\n      banner.classList.remove('opacity-0', 'pointer-events-none');\n      banner.classList.add('opacity-100', 'pointer-events-auto');\n    }, 1500);\n  }\n\n  function saveConsent(analytics: boolean, marketing: boolean): void {\n    const consent = {\n      necessary: true,\n      analytics,\n      marketing,\n      timestamp: new Date().toISOString(),\n    };\n    localStorage.setItem('cookie-consent', JSON.stringify(consent));\n    banner.classList.add('opacity-0', 'pointer-events-none');\n    banner.classList.remove('opacity-100', 'pointer-events-auto');\n  }\n\n  acceptAll.addEventListener('click', () => saveConsent(true, true));\n  acceptSelected.addEventListener('click', () =>\n    saveConsent(analyticsCheckbox.checked, marketingCheckbox.checked)\n  );\n  rejectAll.addEventListener('click', () => saveConsent(false, false));\n</script>\n"
        }
