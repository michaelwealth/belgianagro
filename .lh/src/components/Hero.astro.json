            "date": 1772804415827,
            "name": "Commit-0",
            "content": "---\nimport { Image } from 'astro:assets';\nimport heroBg from '../assets/images/general/hero_bg-image.png';\nimport heroProducts from '../assets/images/general/hero_products.png';\nimport heroLeaves1 from '../assets/images/general/hero_leaves_1.png';\nimport heroLeaves2 from '../assets/images/general/hero_leaves_2.png';\n---\n\n<section\n  id=\"hero\"\n  class=\"relative overflow-hidden min-h-screen\"\n  aria-label=\"Hero section\"\n>\n  <!-- Background Image -->\n  <div class=\"absolute inset-0\" aria-hidden=\"true\">\n    <Image\n      src={heroBg}\n      alt=\"\"\n      class=\"w-full h-full object-cover object-center\"\n      widths={[640, 1024, 1536, 2048]}\n      sizes=\"100vw\"\n      loading=\"eager\"\n    />\n  </div>\n\n  <!-- Subtle gradient overlay for readability -->\n  <div class=\"absolute inset-0 bg-gradient-to-b from-white/40 via-transparent to-bg-glow/30\" aria-hidden=\"true\"></div>\n\n  <!-- Decorative Leaves -->\n  <!-- Leaf 1: Bottom Left -->\n  <Image\n    src={heroLeaves1}\n    alt=\"\"\n    class=\"absolute z-0 pointer-events-none -bottom-4 -left-6 w-32 lg:-bottom-8 lg:-left-12 lg:w-72 animate-float\"\n    loading=\"lazy\"\n    aria-hidden=\"true\"\n  />\n\n  <!-- Leaf 2: Top Center/Right (desktop only) -->\n  <Image\n    src={heroLeaves2}\n    alt=\"\"\n    class=\"absolute z-0 pointer-events-none hidden lg:block lg:-top-4 lg:left-[45%] lg:w-96 animate-float\"\n    style=\"animation-delay: 3s;\"\n    loading=\"lazy\"\n    aria-hidden=\"true\"\n  />\n\n  <!-- Content Wrapper -->\n  <div class=\"relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-28 lg:pt-32 pb-12 lg:pb-20\">\n\n    <!-- Mobile Layout: Image → Text → Card -->\n    <!-- Desktop Layout: Left (Text + Card) | Right (Image) -->\n    <div class=\"flex flex-col lg:flex-row items-center justify-between gap-12\">\n\n      <!-- Mobile: Product Image (shown first on mobile, hidden on desktop) -->\n      <div class=\"lg:hidden w-full flex justify-center animate-fade-in\">\n        <Image\n          src={heroProducts}\n          alt=\"Premium Belgian agrofood products showcase\"\n          class=\"w-full max-w-md rounded-[2rem] shadow-sm object-cover\"\n          widths={[400, 640]}\n          sizes=\"(max-width: 1024px) 90vw, 50vw\"\n          loading=\"eager\"\n        />\n      </div>\n\n      <!-- Left Column: Text + Event Card -->\n      <div class=\"w-full lg:w-1/2 flex flex-col items-center lg:items-start text-center lg:text-left\">\n\n        <!-- H1 Headline -->\n        <h1 class=\"font-jakarta font-bold text-text-main text-2xl md:text-4xl lg:text-5xl leading-[1.1] tracking-tight mb-4 animate-fade-in\">\n          Discover the excellence of companies in Flanders\n        </h1>\n\n        <!-- Sub-headline -->\n        <p class=\"text-text-main text-lg lg:text-xl font-medium mb-8 animate-fade-in\" style=\"animation-delay: 0.1s;\">\n          Visit the Belgian Pavilion at Agrofood Nigeria 2026\n        </p>\n\n        <!-- Single Event Card -->\n        <div class=\"w-full max-w-md animate-fade-in-up\" style=\"animation-delay: 0.25s;\">\n          <div class=\"bg-card-yellow rounded-2xl rounded-tr-[3rem] p-6 lg:p-8 shadow-sm\">\n            <div class=\"flex flex-col gap-4\">\n              <!-- Date Row -->\n              <div class=\"flex items-center gap-3\">\n                <svg class=\"w-5 h-5 flex-shrink-0\" fill=\"none\" stroke=\"#050505\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"/>\n                </svg>\n                <span class=\"font-semibold text-text-main\">24 – 26 March 2026</span>\n              </div>\n\n              <!-- Time Row -->\n              <div class=\"flex items-center gap-3\">\n                <svg class=\"w-5 h-5 flex-shrink-0\" fill=\"none\" stroke=\"#050505\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n                </svg>\n                <span class=\"font-semibold text-text-main\">10:00 – 17:00 Daily</span>\n              </div>\n\n              <!-- Location Row -->\n              <div class=\"flex items-start gap-3\">\n                <svg class=\"w-5 h-5 flex-shrink-0 mt-0.5\" fill=\"none\" stroke=\"#050505\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\"/>\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\"/>\n                </svg>\n                <p class=\"text-text-main\">\n                  <span class=\"font-bold block\">Landmark Event Centre,</span>\n                  <span class=\"block\">Victoria Island, Lagos.</span>\n                </p>\n              </div>\n            </div>\n\n            <!-- Register Link -->\n            <div class=\"mt-4\">\n              <button\n                class=\"text-sm font-bold text-text-main flex items-center gap-1 hover:gap-2 transition-all duration-200\"\n                data-modal=\"nav-modal\"\n              >\n                Register interest\n                <svg class=\"w-3 h-3\" fill=\"currentColor\" viewBox=\"0 0 12 12\" aria-hidden=\"true\">\n                  <path d=\"M4.5 2L9 6l-4.5 4V2z\"/>\n                </svg>\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Right Column: Product Image (desktop only) -->\n      <div class=\"hidden lg:flex w-full lg:w-1/2 justify-center animate-slide-in-right\" style=\"animation-delay: 0.2s;\">\n        <Image\n          src={heroProducts}\n          alt=\"Premium Belgian agrofood products showcase\"\n          class=\"w-full max-w-2xl rounded-[2rem] shadow-sm object-cover\"\n          widths={[640, 1024, 1536]}\n          sizes=\"50vw\"\n          loading=\"lazy\"\n        />\n      </div>\n    </div>\n\n    <!-- Scroll Indicator -->\n    <div class=\"flex justify-center mt-8 mb-4 animate-bounce-subtle\">\n      <a\n        href=\"#companies\"\n        class=\"border border-gray-400 rounded-full w-10 h-10 flex items-center justify-center text-gray-600 hover:border-text-main hover:text-text-main transition-colors\"\n        aria-label=\"Scroll down to view companies\"\n      >\n        <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 14l-7 7m0 0l-7-7m7 7V3\"/>\n        </svg>\n      </a>\n    </div>\n  </div>\n</section>\n"
        }
    ]
}