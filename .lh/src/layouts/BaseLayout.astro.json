            "name": "Commit-0",
            "content": "---\nimport '../styles/global.css';\n\ninterface Props {\n  title: string;\n  description?: string;\n}\n\nconst {\n  title,\n  description = 'Discover premium Belgian agrofood companies at Agrofood Nigeria 2026. Visit the Flanders Investment & Trade pavilion to explore world-class food products and agricultural innovations from Belgium.',\n} = Astro.props;\n\nconst canonicalUrl = 'https://belgianagro.pages.dev';\nconst structuredData = JSON.stringify({\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"Event\",\n  \"name\": \"Belgian Pavilion at Agrofood Nigeria 2026\",\n  \"description\": description,\n  \"startDate\": \"2026-03-24\",\n  \"endDate\": \"2026-03-26\",\n  \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n  \"eventStatus\": \"https://schema.org/EventScheduled\",\n  \"location\": {\n    \"@type\": \"Place\",\n    \"name\": \"Landmark Event Centre\",\n    \"address\": {\n      \"@type\": \"PostalAddress\",\n      \"addressLocality\": \"Lagos\",\n      \"addressRegion\": \"Victoria Island\",\n      \"addressCountry\": \"NG\"\n    }\n  },\n  \"organizer\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Flanders Investment & Trade (FIT)\",\n    \"url\": \"https://www.flandersinvestmentandtrade.com\"\n  }\n});\n---\n\n<!doctype html>\n<html lang=\"en\" class=\"scroll-smooth\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <meta name=\"description\" content={description} />\n    <meta name=\"author\" content=\"Flanders Investment & Trade (FIT)\" />\n    <meta name=\"keywords\" content=\"Belgian agrofood, Flanders Investment Trade, Agrofood Nigeria 2026, Belgian Pavilion Lagos, Belgium food exports, Flanders companies Nigeria\" />\n    <meta name=\"robots\" content=\"index, follow\" />\n    <link rel=\"canonical\" href={canonicalUrl} />\n\n    <!-- Content Security Policy -->\n    <meta\n      http-equiv=\"Content-Security-Policy\"\n      content=\"default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self';\"\n    />\n\n    <!-- Preload critical fonts -->\n    <link rel=\"preload\" href=\"/fonts/plus-jakarta-sans-latin-700.woff2\" as=\"font\" type=\"font/woff2\" crossorigin />\n    <link rel=\"preload\" href=\"/fonts/inter-latin-400.woff2\" as=\"font\" type=\"font/woff2\" crossorigin />\n\n    <!-- Favicon -->\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"favicon.svg\" />\n\n    <!-- Open Graph -->\n    <meta property=\"og:title\" content={title} />\n    <meta property=\"og:description\" content={description} />\n    <meta property=\"og:type\" content=\"website\" />\n    <meta property=\"og:locale\" content=\"en_US\" />\n    <meta property=\"og:url\" content={canonicalUrl} />\n    <meta property=\"og:site_name\" content=\"Belgian Pavilion - Agrofood Nigeria 2026\" />\n    <meta property=\"og:image\" content={`${canonicalUrl}og-image.png`} />\n\n    <!-- Twitter Card -->\n    <meta name=\"twitter:card\" content=\"summary_large_image\" />\n    <meta name=\"twitter:title\" content={title} />\n    <meta name=\"twitter:description\" content={description} />\n    <meta name=\"twitter:image\" content={`${canonicalUrl}og-image.png`} />\n\n    <!-- Structured Data (JSON-LD) -->\n    <script type=\"application/ld+json\" set:html={structuredData} />\n\n    <title>{title}</title>\n\n    <style>\n      body {\n        margin: 0;\n        min-height: 100vh;\n      }\n    </style>\n  </head>\n  <body class=\"font-inter text-gray-900 bg-white antialiased\">\n    <a\n      href=\"#main-content\"\n      class=\"sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-text-main focus:text-white focus:px-4 focus:py-2 focus:rounded-lg\"\n    >\n      Skip to main content\n    </a>\n    <slot />\n  </body>\n</html>\n"
        }
