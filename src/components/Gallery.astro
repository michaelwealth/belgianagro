---
/**
 * Gallery Section — Masonry Layout
 * Uses CSS columns for a dead-space-free masonry grid.
 * Since we don't have actual gallery images yet, we generate
 * placeholder slots that can be replaced with real images.
 */

// Gallery placeholder data — replace with real images when available
const galleryImages = [
  { alt: 'Belgian agricultural innovation showcase', aspect: 'tall' },
  { alt: 'Premium food product demonstration', aspect: 'wide' },
  { alt: 'Flanders trade pavilion exhibition', aspect: 'square' },
  { alt: 'Agrofood networking event', aspect: 'tall' },
  { alt: 'Agricultural equipment display', aspect: 'wide' },
  { alt: 'Food processing innovation workshop', aspect: 'square' },
  { alt: 'Belgian-Nigerian partnership signing', aspect: 'tall' },
  { alt: 'Sustainable agriculture presentation', aspect: 'wide' },
  { alt: 'Premium food product showcase', aspect: 'square' },
  { alt: 'Trade delegation meeting', aspect: 'tall' },
  { alt: 'Innovation lab demonstration', aspect: 'wide' },
  { alt: 'Food processing technology display', aspect: 'square' },
];

const aspectClasses: Record<string, string> = {
  tall: 'h-72 lg:h-96',
  wide: 'h-48 lg:h-56',
  square: 'h-56 lg:h-64',
};

const gradients = [
  'from-card-yellow/40 to-bg-glow/30',
  'from-emerald-100/60 to-card-yellow/20',
  'from-bg-glow/30 to-amber-100/40',
  'from-sky-100/50 to-card-yellow/20',
  'from-card-yellow/20 to-emerald-100/30',
  'from-amber-50/40 to-bg-glow/20',
];
---

<section
  id="gallery"
  class="w-full py-16 lg:py-24 bg-white"
  aria-labelledby="gallery-heading"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16">
      <span class="inline-block bg-text-main/10 text-text-main rounded-full px-4 py-1.5 text-sm font-medium mb-4">
        Highlights
      </span>
      <h2 id="gallery-heading" class="section-title mb-4">
        Event Gallery
      </h2>
      <p class="text-text-light-blue text-base lg:text-lg max-w-2xl mx-auto">
        Explore moments from previous Belgian trade missions and agrofood events across Africa.
      </p>
    </div>

    <!-- Masonry Grid -->
    <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
      {galleryImages.map((img, i) => (
        <div class={`break-inside-avoid rounded-xl overflow-hidden hover:opacity-90 transition-opacity duration-300 ${aspectClasses[img.aspect]} bg-gradient-to-br ${gradients[i % gradients.length]} relative group`}>
          <!-- Placeholder with icon and text -->
          <div class="absolute inset-0 flex flex-col items-center justify-center p-4">
            <svg class="w-12 h-12 text-text-main/30 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-text-main/40 text-xs text-center font-medium">
              {img.alt}
            </p>
          </div>
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-text-main/0 group-hover:bg-text-main/5 transition-colors duration-300 rounded-xl"></div>
        </div>
      ))}
    </div>
  </div>
</section>
