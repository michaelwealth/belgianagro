---
import { Image } from 'astro:assets';
import fitLogo from '../assets/images/fit_logo.png';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Server error — Belgian Pavilion</title>
  </head>
  <body class="font-inter bg-white text-gray-900 antialiased min-h-screen flex flex-col">
    <!-- Minimal header (logo only) -->
    <header class="w-full py-4">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center">
        <a href="/" aria-label="Home" class="inline-block">
          <Image src={fitLogo} alt="FIT logo" width={160} height={48} class="h-10 w-auto" />
        </a>
      </div>
    </header>

    <!-- Hero -->
    <main class="flex-1 flex items-center justify-center">
      <div class="max-w-4xl mx-auto text-center px-6 py-20">
        <div class="relative mx-auto mb-8" style="width:9rem; height:9rem;">
          <div class="absolute inset-0 flex items-center justify-center rounded-full bg-bg-glow/70 shadow-xl">
            <h1 class="text-4xl font-jakarta font-extrabold text-text-main">500</h1>
          </div>
          <!-- Decorative SVG: informal pattern to match homepage accents -->
          <svg aria-hidden="true" class="absolute -bottom-6 -right-6 w-20 h-20" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="6" width="36" height="36" rx="8" fill="#FCFFEB" fill-opacity="0.95"/>
            <circle cx="84" cy="28" r="16" fill="#FDF7D5"/>
            <path d="M24 84c14-8 34-6 46 2s28 14 40 6" stroke="#E6C77A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" opacity="0.95"/>
          </svg>
        </div>
        <h2 class="text-3xl md:text-4xl font-jakarta font-bold mb-4">Something went wrong</h2>
        <p class="text-gray-600 mb-8">We're experiencing a server error. Try refreshing the page or come back later.</p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <button onclick="location.reload()" class="btn-blue inline-flex items-center justify-center px-6 py-3 rounded-full font-semibold">Retry</button>
          <a href="/#companies" class="inline-flex items-center justify-center px-6 py-3 rounded-full border border-gray-200 text-text-main hover:bg-gray-50">View companies</a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
